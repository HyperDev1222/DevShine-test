{% comment %} 
  Floating quick-add bar for KNR product editorial section.
 
  Accepts: 
  - product: {Object} Product (required) 
  - section: {Object} Section for labels 
  - variant: {Object} Selected variant 
{% endcomment %}
{%- liquid
  if variant == blank and product != blank
    assign variant = product.selected_or_first_available_variant
  endif

  assign form_id = 'knr-editorial-form-' | append: section.id
  assign featured_image = variant.featured_media | default: product.featured_media
-%}

<div
  class="knr-editorial-quick-add"
  data-knr-editorial-quick-add
  data-section-id="{{ section.id }}">
  <div class="knr-editorial-quick-add__media">
    {%- if featured_image -%}
      {{ featured_image
 | image_url: width: 160
 | image_tag:
 loading: 'lazy',
 class: 'knr-editorial-quick-add__img',
 data-knr-editorial-image: true,
 alt: product.title,
 widths: '80, 120, 160'
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'knr-editorial-quick-add__img knr-editorial-quick-add__img--placeholder' }}
    {%- endif -%}
  </div>

  <div class="knr-editorial-quick-add__info">
    <p class="knr-editorial-quick-add__title">{{ product.title | escape }}</p>

    {%- unless product.has_only_default_variant -%}
      <div class="knr-editorial-quick-add__variants">
        {%- for option in product.options_with_values -%}
          {%- for value in option.values -%}
            {%- liquid
              assign is_selected = false
              if option.selected_value == value
                assign is_selected = true
              endif
            -%}
            <button
              type="button"
              class="knr-editorial-quick-add__variant{% if is_selected %} knr-editorial-quick-add__variant--active{% endif %}"
              data-knr-editorial-option
              data-option-index="{{ forloop.parentloop.index0 }}"
              data-value="{{ value | escape }}"
              aria-pressed="{{ is_selected }}">
              {{ value | escape }}
            </button>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    {%- endunless -%}

    <div class="knr-editorial-quick-add__price-wrap">
      {%- assign editorial_price_id = 'knr-editorial-price-' | append: section.id -%}
      {% render 'knr-price'
        , variant: variant
        , id: editorial_price_id
        , price_class: 'knr-editorial-quick-add__price' %}
    </div>
  </div>

  {%- form 'product'
    , product
    , id: form_id
    , class: 'knr-editorial-quick-add__form'
    , data-knr-add-to-cart-form: true -%}
    <input
      type="hidden"
      name="id"
      value="{{ variant.id }}"
      data-knr-editorial-variant-id
      {% unless variant.available %}
      disabled{% endunless %}>

    <button
      type="submit"
      class="knr-editorial-quick-add__submit"
      data-knr-add-to-cart
      data-knr-editorial-submit
      data-label-available="{{ section.settings.add_to_cart_label | escape }}"
      data-label-sold-out="{{ section.settings.sold_out_label | escape }}"
      {% unless variant.available %}
      disabled{% endunless %}>
      {%- if variant.available -%}
        {{ section.settings.add_to_cart_label | escape }}
      {%- else -%}
        {{ section.settings.sold_out_label | escape }}
      {%- endif -%}
    </button>
  {%- endform -%}
</div>