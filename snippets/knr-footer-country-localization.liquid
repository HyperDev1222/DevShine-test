{%- comment -%}
  Footer country/currency picker — compact "France (€)" label.

  Accepts:
    - localPosition: {String}
{%- endcomment -%}

<div class="disclosure knr-footer__locale">
  <button
    type="button"
    class="disclosure__button localization-form__select knr-footer__locale-trigger"
    aria-expanded="false"
    aria-controls="{{ localPosition }}-country-results"
    aria-describedby="{{ localPosition }}Label"
  >
    <span class="knr-footer__locale-label">
      {{- localization.country.name }} ({{ localization.country.currency.symbol }})
    </span>
    <span class="knr-footer__locale-caret" aria-hidden="true">
      {{- 'icon-caret.svg' | inline_asset_content -}}
    </span>
  </button>

  <div class="disclosure__list-wrapper country-selector knr-footer__locale-panel" hidden>
    <ul role="list" class="disclosure__list country-selector__list list-unstyled" id="{{ localPosition }}-country-results">
      {%- for country in localization.available_countries -%}
        <li class="disclosure__item" tabindex="-1">
          <a
            class="link link--text disclosure__link knr-footer__locale-option focus-inset"
            href="#"
            {% if country.iso_code == localization.country.iso_code %}
              aria-current="true"
            {% endif %}
            data-value="{{ country.iso_code }}"
            id="{{ localPosition }}-country-{{ country.iso_code }}"
          >
            <span
              class="knr-footer__locale-check"
              {% if country.iso_code != localization.country.iso_code %}
                hidden
              {% endif %}
            >
              {{- 'icon-checkmark.svg' | inline_asset_content -}}
            </span>
            <span class="country">{{ country.name }} ({{ country.currency.symbol }})</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>
<input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
