{{ 'knr-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'knr-cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'knr-header.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign header_height = section.settings.padding_top | plus: section.settings.padding_bottom | plus: 40
  assign mobile_padding_top = section.settings.padding_top | times: 0.75 | round
  assign mobile_padding_bottom = section.settings.padding_bottom | times: 0.75 | round
  assign mobile_header_height = mobile_padding_top | plus: mobile_padding_bottom | plus: 32
-%}

<header
  class="knr-header{% if section.settings.enable_overlay %} knr-header--overlay{% endif %}"
  data-section-id="{{ section.id }}"
  role="banner"
  style="--knr-header-height: {{ header_height }}px;"
>
  <div class="knr-header__inner">
    <div class="knr-header__col knr-header__col--logo">
      {%- if settings.logo != blank -%}
        {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
        {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
        {%- capture logo_sizes -%}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{%- endcapture -%}
        {%- capture logo_widths -%}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{%- endcapture -%}
        <a
          href="{{ routes.root_url }}"
          class="knr-header__logo"
          style="--knr-logo-width: {{ settings.logo_width }}px;"
        >
          {{
            settings.logo
            | image_url: width: 600
            | image_tag:
              class: 'knr-header__logo-image',
              alt: logo_alt,
              widths: logo_widths,
              width: settings.logo_width,
              height: logo_height,
              sizes: logo_sizes
          }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.menu != blank -%}
      <nav class="knr-header__col knr-header__col--nav" aria-label="{{ section.settings.menu.title | escape }}">
        <ul class="knr-header__menu">
          {%- for link in section.settings.menu.links -%}
            <li class="knr-header__menu-item">
              <a
                href="{{ link.url }}"
                class="knr-header__menu-link{% if link.active %} knr-header__menu-link--active{% endif %}"
                {% if link.current %}aria-current="page"{% endif %}
              >
                {{ link.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="knr-header__col knr-header__col--actions">
      <a
        href="{{ section.settings.store_locator_url | default: '#' }}"
        class="knr-header__icon-btn"
        aria-label="{{ section.settings.store_locator_label | escape }}"
        {% if section.settings.store_locator_url == blank %}aria-disabled="true" tabindex="-1"{% endif %}
      >
        <svg class="knr-header__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M10 18s5-4.5 5-9a5 5 0 10-10 0c0 4.5 5 9 5 9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <circle cx="10" cy="9" r="2" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </a>

      <a
        href="{{ routes.account_url }}"
        class="knr-header__icon-btn knr-header__icon-btn--desktop"
        aria-label="{{ section.settings.account_label | escape }}"
      >
        <svg class="knr-header__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M4 17c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>

      {% render 'knr-header-search', section_id: section.id, search_label: section.settings.search_label %}

      <a href="{{ routes.cart_url }}" class="knr-header__icon-btn knr-header__cart" aria-label="{{ 'templates.cart.cart' | t }}">
        <svg class="knr-header__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 6h12l-1.2 7H6.2L5 6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M5 6L4 3H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="8" cy="16.5" r="1" fill="currentColor"/>
          <circle cx="14" cy="16.5" r="1" fill="currentColor"/>
        </svg>
        <span
          class="knr-header__cart-badge{% if cart.item_count < 1 %} knr-header__cart-badge--empty{% endif %}"
          data-knr-cart-badge
          {% if cart.item_count < 1 %}hidden{% endif %}
        >
          <span data-knr-cart-count>{{ cart.item_count }}</span>
        </span>
      </a>

      <button
        type="button"
        class="knr-header__menu-toggle"
        aria-label="{{ section.settings.mobile_menu_label | escape }}"
        aria-expanded="false"
        data-knr-menu-toggle
      >
        <span class="knr-header__menu-toggle-bar"></span>
        <span class="knr-header__menu-toggle-bar"></span>
      </button>
    </div>
  </div>

  {%- if section.settings.menu != blank -%}
    <nav class="knr-header__mobile-nav" hidden data-knr-mobile-nav aria-label="{{ section.settings.menu.title | escape }}">
      <ul class="knr-header__mobile-menu">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a href="{{ link.url }}" class="knr-header__mobile-link">{{ link.title | escape }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
</header>

{%- style -%}
  .knr-header[data-section-id="{{ section.id }}"] {
    --knr-header-text: {{ section.settings.text_color }};
    --knr-header-padding-top: {{ section.settings.padding_top }}px;
    --knr-header-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  {%- if section.settings.enable_overlay -%}
    #shopify-section-{{ section.id }} {
      --knr-header-height: {{ header_height }}px;
    }

    #shopify-section-{{ section.id }} + .shopify-section {
      --knr-header-height: {{ header_height }}px;
    }

    @media screen and (max-width: 989px) {
      #shopify-section-{{ section.id }} {
        --knr-header-height: {{ mobile_header_height }}px;
      }

      #shopify-section-{{ section.id }} + .shopify-section {
        --knr-header-height: {{ mobile_header_height }}px;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{% schema %}
{
  "name": "KNR Header",
  "tag": "section",
  "class": "knr-section-header",
  "settings": [
    {
      "type": "paragraph",
      "content": "Logo is managed in Theme settings > Logo."
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Transparent overlay on section below",
      "default": true,
      "info": "Header background becomes transparent and overlaps the next section"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and icon color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "url",
      "id": "store_locator_url",
      "label": "Store locator URL"
    },
    {
      "type": "text",
      "id": "store_locator_label",
      "label": "Store locator label",
      "default": "Store locator"
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account label",
      "default": "Account"
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "mobile_menu_label",
      "label": "Mobile menu button label",
      "default": "Open menu"
    }
  ],
  "presets": [
    {
      "name": "KNR Header"
    }
  ]
}
{% endschema %}
