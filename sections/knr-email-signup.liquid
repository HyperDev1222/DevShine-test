{{ 'knr-email-signup.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign desktop_image = section.settings.image_desktop
  assign mobile_image = section.settings.image_mobile | default: desktop_image
-%}

<section class="knr-email-signup" data-section-id="{{ section.id }}">
  <div class="knr-email-signup__inner">
    {%- if desktop_image != blank -%}
      <div class="knr-email-signup__media knr-email-signup__media--desktop">
        {{
          desktop_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'knr-email-signup__img',
            sizes: '(min-width: 769px) 50vw, 0px',
            widths: '600, 900, 1200'
        }}
      </div>
    {%- endif -%}

    {%- if mobile_image != blank -%}
      <div class="knr-email-signup__media knr-email-signup__media--mobile">
        {{
          mobile_image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            class: 'knr-email-signup__img',
            sizes: '100vw',
            widths: '400, 600, 800'
        }}
      </div>
    {%- endif -%}

    <div class="knr-email-signup__content">
      {%- if section.settings.desktop_heading != blank -%}
        <div class="knr-email-signup__heading knr-email-signup__heading--desktop">
          {{ section.settings.desktop_heading | escape | newline_to_br }}
        </div>
      {%- endif -%}

      {%- if section.settings.mobile_heading != blank -%}
        <div class="knr-email-signup__heading knr-email-signup__heading--mobile">
          {{ section.settings.mobile_heading | escape | newline_to_br }}
        </div>
      {%- endif -%}

      {% render 'knr-email-signup-form', section: section %}

      {%- if section.settings.disclaimer != blank -%}
        <p class="knr-email-signup__disclaimer">{{ section.settings.disclaimer | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KNR Email Signup",
  "tag": "section",
  "class": "knr-section-email-signup",
  "settings": [
    {
      "type": "paragraph",
      "content": "Uses Shopify customer newsletter signup. Subscribers are added to your store email list (Customers → accepts marketing)."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Optional. Falls back to desktop image."
    },
    {
      "type": "header",
      "content": "Desktop content"
    },
    {
      "type": "textarea",
      "id": "desktop_heading",
      "label": "Desktop heading",
      "default": "L'alliance de la science botanique et du luxe naturel pour une peau visiblement rajeunie en 4 semaines."
    },
    {
      "type": "header",
      "content": "Mobile content"
    },
    {
      "type": "textarea",
      "id": "mobile_heading",
      "label": "Mobile heading",
      "default": "Sérum précieux régénérant — l'alliance de la science botanique et du luxe naturel pour une peau visiblement rajeunie en 4 semaines."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "S'inscrire"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Merci pour votre inscription."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Formule brevetée, testée dermatologiquement, 97 % d'ingrédients d'origine naturelle."
    }
  ],
  "presets": [
    {
      "name": "KNR Email Signup"
    }
  ]
}
{% endschema %}
