{{ 'knr-latest-news.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
<script src="{{ 'knr-latest-news.js' | asset_url }}" defer="defer"></script>

<section class="knr-latest-news" data-section-id="{{ section.id }}" data-knr-latest-news>
  <div class="knr-latest-news__inner">
    <div class="knr-latest-news__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="knr-latest-news__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.show_view_all and section.settings.blog != blank -%}
        <a href="{{ section.settings.blog.url }}" class="knr-latest-news__view-all knr-latest-news__view-all--header">
          {{ section.settings.view_all_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <div class="knr-latest-news__divider" aria-hidden="true"></div>

    {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
      {%- assign article_limit = section.settings.post_limit -%}
      <div
        class="knr-latest-news__slider swiper"
        data-knr-news-swiper
        style="--knr-news-columns: {{ article_limit | at_most: 4 }};"
      >
        <div class="swiper-wrapper knr-latest-news__grid">
          {%- for article in section.settings.blog.articles limit: article_limit -%}
            {% render 'knr-latest-news-card',
              article: article,
              show_image: section.settings.show_image
            %}
          {%- endfor -%}
        </div>

        <div class="knr-latest-news__progress" data-knr-news-progress role="tablist" aria-label="{{ section.settings.heading | escape }}">
          {%- for article in section.settings.blog.articles limit: article_limit -%}
            <button
              type="button"
              class="knr-latest-news__progress-segment{% if forloop.first %} is-active{% endif %}"
              data-knr-news-progress-segment
              data-slide-index="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="Go to article {{ forloop.index }}"
            ></button>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.settings.show_view_all -%}
        <div class="knr-latest-news__footer">
          <a href="{{ section.settings.blog.url }}" class="knr-latest-news__view-all knr-latest-news__view-all--footer">
            {{ section.settings.view_all_label | escape }}
          </a>
        </div>
      {%- endif -%}
    {%- elsif section.settings.blog == blank -%}
      <p class="knr-latest-news__empty">{{ section.settings.empty_message | escape }}</p>
    {%- else -%}
      <p class="knr-latest-news__empty">{{ section.settings.no_articles_message | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KNR Latest News",
  "tag": "section",
  "class": "knr-section-latest-news",
  "settings": [
    {
      "type": "paragraph",
      "content": "Articles are pulled from a Shopify blog. Use the article title as the card label, an h3 in the content as the card heading, and excerpt or first paragraph as body text."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Latest news"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "label": "Number of articles",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show featured image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Voir tous les articles"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "No blog selected message",
      "default": "Select a blog in theme settings to display articles."
    },
    {
      "type": "text",
      "id": "no_articles_message",
      "label": "No articles message",
      "default": "No articles published yet."
    }
  ],
  "presets": [
    {
      "name": "KNR Latest News"
    }
  ]
}
{% endschema %}
