{{ 'knr-product-main.css' | asset_url | stylesheet_tag }}
<script src="{{ 'knr-variant-picker.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'knr-cart.js' | asset_url }}" defer="defer"></script>

{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'knr-product-form-' | append: section.id -%}

<section
  class="knr-product-main"
  data-section-id="{{ section.id }}"
  data-knr-variant-picker
  data-money-format="{{ shop.money_format | escape }}"
>
  <div class="knr-product-main__inner">
    <div class="knr-product-main__gallery">
      <div class="knr-product-main__main-image-wrap">
        {%- if product.featured_media -%}
          {{
            product.featured_media
            | image_url: width: 1200
            | image_tag:
              class: 'knr-product-main__main-image',
              data-knr-main-image: true,
              loading: 'eager',
              alt: product.featured_media.alt | default: product.title,
              widths: '400, 600, 800, 1000, 1200'
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'knr-product-main__placeholder' }}
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <ul class="knr-product-main__thumbnails" role="list">
          {%- for image in product.images -%}
            <li class="knr-product-main__thumbnail-item">
              <button
                type="button"
                class="knr-product-main__thumbnail{% if forloop.first %} knr-product-main__thumbnail--active{% endif %}"
                data-knr-thumbnail
                data-image-src="{{ image | image_url: width: 1200 }}"
                data-image-alt="{{ image.alt | default: product.title | escape }}"
                aria-label="{{ section.settings.thumbnail_label | escape }} {{ forloop.index }}"
              >
                {{
                  image
                  | image_url: width: 120
                  | image_tag: loading: 'lazy', alt: image.alt | default: product.title, widths: '80, 120'
                }}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="knr-product-main__info">
      {%- if section.settings.show_vendor and product.vendor != blank -%}
        <p class="knr-product-main__vendor">{{ product.vendor | escape }}</p>
      {%- endif -%}

      <h1 class="knr-product-main__title">{{ product.title | escape }}</h1>

      <div class="knr-product-main__price-wrap">
        {%- assign knr_price_id = 'knr-price-' | append: section.id -%}
        {% render 'knr-price', variant: selected_variant, id: knr_price_id %}
      </div>

      {%- unless product.has_only_default_variant -%}
        <div class="knr-product-main__variants">
          {%- for option in product.options_with_values -%}
            <fieldset class="knr-product-main__option" data-knr-option-group>
              <legend class="knr-product-main__option-label">{{ option.name | escape }}</legend>
              <div class="knr-product-main__option-values">
                {%- for value in option.values -%}
                  {%- liquid
                    assign is_selected = false
                    if option.selected_value == value
                      assign is_selected = true
                    endif
                  -%}
                  <label class="knr-product-main__option-value{% if is_selected %} knr-product-main__option-value--selected{% endif %}">
                    <input
                      type="radio"
                      name="options[{{ option.name | escape }}]"
                      value="{{ value | escape }}"
                      data-knr-option
                      {% if is_selected %}checked{% endif %}
                      class="knr-product-main__option-input visually-hidden"
                    >
                    <span>{{ value | escape }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- form 'product', product, id: product_form_id, class: 'knr-product-main__form', data-knr-add-to-cart-form: true -%}
        <input
          type="hidden"
          name="id"
          value="{{ selected_variant.id }}"
          data-knr-variant-id
          {% unless selected_variant.available %}disabled{% endunless %}
        >

        <button
          type="submit"
          class="knr-product-main__submit"
          data-knr-add-to-cart
          data-label-available="{{ section.settings.add_to_cart_label | escape }}"
          data-label-sold-out="{{ section.settings.sold_out_label | escape }}"
          {% unless selected_variant.available %}disabled{% endunless %}
        >
          {%- if selected_variant.available -%}
            {{ section.settings.add_to_cart_label | escape }}
          {%- else -%}
            {{ section.settings.sold_out_label | escape }}
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- if product.description != blank -%}
        <div class="knr-product-main__description rte">
          {{ product.description }}
        </div>
      {%- endif -%}
    </div>
  </div>

  <script type="application/json" data-knr-product-json>
    {
      "id": {{ product.id | json }},
      "title": {{ product.title | json }},
      "handle": {{ product.handle | json }},
      "variants": [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id | json }},
            "title": {{ variant.title | json }},
            "price": {{ variant.price | json }},
            "compare_at_price": {{ variant.compare_at_price | json }},
            "available": {{ variant.available | json }},
            "options": {{ variant.options | json }},
            "featured_media": {% if variant.featured_media %}{
              "id": {{ variant.featured_media.id | json }},
              "preview_image": {
                "src": {{ variant.featured_media | image_url: width: 1200 | json }},
                "alt": {{ variant.featured_media.alt | default: product.title | json }}
              }
            }{% else %}null{% endif %}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-knr-thumbnail]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var mainImage = document.querySelector('[data-knr-main-image]');
        if (!mainImage) return;
        mainImage.src = btn.dataset.imageSrc;
        if (btn.dataset.imageAlt) mainImage.alt = btn.dataset.imageAlt;
        btn.closest('.knr-product-main__thumbnails')
          ?.querySelectorAll('[data-knr-thumbnail]')
          .forEach(function (t) { t.classList.remove('knr-product-main__thumbnail--active'); });
        btn.classList.add('knr-product-main__thumbnail--active');
      });
    });

    document.querySelectorAll('[data-knr-option]').forEach(function (input) {
      input.addEventListener('change', function () {
        var group = input.closest('[data-knr-option-group]');
        group?.querySelectorAll('.knr-product-main__option-value').forEach(function (label) {
          label.classList.remove('knr-product-main__option-value--selected');
        });
        input.closest('.knr-product-main__option-value')?.classList.add('knr-product-main__option-value--selected');
      });
    });
  });
</script>

{% schema %}
{
  "name": "KNR Product Main",
  "tag": "section",
  "class": "knr-section-product-main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Add to cart button label",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out button label",
      "default": "Sold out"
    },
    {
      "type": "text",
      "id": "thumbnail_label",
      "label": "Thumbnail accessibility label",
      "default": "View image"
    }
  ],
  "presets": [
    {
      "name": "KNR Product Main"
    }
  ]
}
{% endschema %}
