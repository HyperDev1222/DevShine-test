{{ 'knr-before-after.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
<script src="{{ 'knr-before-after.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign comparison = product.metafields.knr.before_after.value
  assign testimonials = product.metafields.knr.testimonials.value
-%}

<section class="knr-before-after" data-section-id="{{ section.id }}" data-knr-before-after>
  <div class="knr-before-after__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="knr-before-after__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="knr-before-after__description">{{ section.settings.description | escape | newline_to_br }}</p>
    {%- endif -%}

    {%- if comparison != blank -%}
      {% render 'knr-before-after-comparison',
        comparison: comparison,
        before_label_fallback: section.settings.before_label,
        after_label_fallback: section.settings.after_label
      %}
    {%- elsif request.design_mode -%}
      <p class="knr-before-after__empty">
        Add a <strong>Before &amp; after</strong> metaobject via product metafield
        <strong>knr.before_after</strong>.
      </p>
    {%- endif -%}

    {%- if testimonials != blank and testimonials.size > 0 -%}
      <div class="knr-ba-testimonials" data-knr-ba-testimonials>
        <div class="swiper knr-ba-testimonials__swiper" data-knr-ba-testimonials-swiper>
          <div class="swiper-wrapper">
            {%- for testimonial in testimonials -%}
              {% render 'knr-testimonial-slide', testimonial: testimonial %}
            {%- endfor -%}
          </div>
        </div>

        <div class="knr-ba-testimonials__nav">
          <button
            type="button"
            class="knr-ba-testimonials__nav-btn knr-ba-testimonials__nav-btn--prev"
            data-knr-ba-testimonials-prev
            aria-label="{{ section.settings.prev_label | escape }}"
          >
            <span aria-hidden="true">‹</span>
          </button>
          <button
            type="button"
            class="knr-ba-testimonials__nav-btn knr-ba-testimonials__nav-btn--next"
            data-knr-ba-testimonials-next
            aria-label="{{ section.settings.next_label | escape }}"
          >
            <span aria-hidden="true">›</span>
          </button>
        </div>
      </div>
    {%- elsif request.design_mode and comparison != blank -%}
      <p class="knr-before-after__empty knr-before-after__empty--testimonials">
        Add testimonials via product metafield <strong>knr.testimonials</strong>.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KNR Before After",
  "tag": "section",
  "class": "knr-section-before-after",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Comparison and testimonials come from product metafields knr.before_after and knr.testimonials. See README."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ce que disent nos clientes"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Des transformations visibles dès 4 semaines. Nos clientes témoignent d'une peau visiblement régénérée, plus ferme et lumineuse."
    },
    {
      "type": "header",
      "content": "Comparison labels (fallback)"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "BEFORE"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "AFTER"
    },
    {
      "type": "header",
      "content": "Testimonial slider"
    },
    {
      "type": "text",
      "id": "prev_label",
      "label": "Previous testimonial label",
      "default": "Previous testimonial"
    },
    {
      "type": "text",
      "id": "next_label",
      "label": "Next testimonial label",
      "default": "Next testimonial"
    }
  ],
  "presets": [
    {
      "name": "KNR Before After"
    }
  ]
}
{% endschema %}
