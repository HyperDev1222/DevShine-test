{{ 'knr-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'knr-faq.js' | asset_url }}" defer="defer"></script>

<section class="knr-faq" data-section-id="{{ section.id }}" data-knr-faq>
  <div class="knr-faq__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="knr-faq__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="knr-faq__list" role="list">
        {%- for block in section.blocks -%}
          <div
            class="knr-faq__item{% if section.settings.open_first and forloop.first %} knr-faq__item--open{% endif %}"
            data-knr-faq-item
            {{ block.shopify_attributes }}
          >
            <button
              type="button"
              class="knr-faq__trigger"
              data-knr-faq-trigger
              aria-expanded="{% if section.settings.open_first and forloop.first %}true{% else %}false{% endif %}"
              aria-controls="knr-faq-panel-{{ block.id }}"
            >
              <span class="knr-faq__question">{{ block.settings.question | escape }}</span>
              <span class="knr-faq__icon" aria-hidden="true"></span>
            </button>
            <div
              id="knr-faq-panel-{{ block.id }}"
              class="knr-faq__panel rte"
              data-knr-faq-panel
              role="region"
              {% unless section.settings.open_first and forloop.first %}hidden{% endunless %}
            >
              {{ block.settings.answer }}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KNR FAQ",
  "tag": "section",
  "class": "knr-section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KNR FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I use this product?",
            "answer": "<p>Apply as directed on the packaging.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What are the ingredients?",
            "answer": "<p>See the product description for full ingredient list.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer 30-day returns on unopened products.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
