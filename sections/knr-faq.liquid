{{ 'knr-faq.css' | asset_url | stylesheet_tag }}
<script src="{{ 'knr-faq.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign faq_items = product.metafields.knr.faq_items.value
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'Questions fréquentes'
  endif
-%}

<section class="knr-faq" data-section-id="{{ section.id }}" data-knr-faq>
  <div class="knr-faq__inner">
    <h2 class="knr-faq__heading">{{ heading | escape }}</h2>

    {%- if faq_items != blank and faq_items.size > 0 -%}
      <div class="knr-faq__list">
        {%- for item in faq_items -%}
          {%- liquid
            assign item_open = false
            if section.settings.open_first and forloop.first
              assign item_open = true
            endif
          -%}
          {% render 'knr-faq-item',
            item: item,
            section_id: section.id,
            index: forloop.index,
            open: item_open
          %}
        {%- endfor -%}
      </div>
    {%- elsif request.design_mode -%}
      <p class="knr-faq__empty">
        Add FAQ entries via product metafield <strong>knr.faq_items</strong> (list of
        <em>FAQ item</em> metaobjects).
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KNR FAQ",
  "tag": "section",
  "class": "knr-section-faq",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "FAQ items come from the product metafield knr.faq_items (list of FAQ item metaobjects). See README."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions fréquentes"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "KNR FAQ"
    }
  ]
}
{% endschema %}
