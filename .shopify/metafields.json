{
  "definitions": [
    {
      "namespace": "knr",
      "key": "text_above_variant",
      "name": "Text above variant",
      "description": "Short product text displayed above the variant picker (Taille).",
      "type": "multi_line_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "tags",
      "name": "Product badges",
      "description": "Badge labels shown above the product title (e.g. UNIFIE, PROTÈGE).",
      "type": "list.single_line_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "rating_score",
      "name": "Rating score",
      "description": "Numeric product rating (e.g. 4.7).",
      "type": "number_decimal",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "rating_count",
      "name": "Rating count label",
      "description": "Review count text (e.g. 200 avis).",
      "type": "single_line_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "certification",
      "name": "Certification line",
      "description": "Yuka / INCI certification text below the title.",
      "type": "rich_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "stock_message",
      "name": "Stock message",
      "description": "Delivery/stock text below the Add to cart button.",
      "type": "single_line_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "description",
      "name": "Description accordion",
      "description": "Rich text for the Description accordion. Falls back to native product description if empty.",
      "type": "rich_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "description_image",
      "name": "Description image",
      "description": "Optional image shown inside the Description accordion.",
      "type": "file_reference",
      "ownerType": "PRODUCT",
      "validations": [{ "name": "file_type_options", "value": "[\"Image\"]" }]
    },
    {
      "namespace": "knr",
      "key": "benefits",
      "name": "Benefits accordion",
      "description": "Rich text for the Bienfaits accordion.",
      "type": "rich_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "key_ingredients",
      "name": "Key ingredients accordion",
      "description": "Rich text for the Ingrédients clés accordion.",
      "type": "rich_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "skin_types",
      "name": "Skin types accordion",
      "description": "Rich text for the Adapté aux peaux accordion.",
      "type": "rich_text_field",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "how_to_use_steps",
      "name": "How to use steps",
      "description": "Ordered list of How to use step metaobjects for the product page.",
      "type": "list.metaobject_reference",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "before_after",
      "name": "Before and after",
      "description": "Before/after image comparison for the Before & After section.",
      "type": "metaobject_reference",
      "ownerType": "PRODUCT"
    },
    {
      "namespace": "knr",
      "key": "testimonials",
      "name": "Testimonials",
      "description": "Customer testimonials for the Before & After section slider.",
      "type": "list.metaobject_reference",
      "ownerType": "PRODUCT"
    }
  ],
  "metaobject_definitions": [
    {
      "name": "How to use step",
      "type": "knr_how_to_use_step",
      "access": {
        "storefront": "PUBLIC_READ"
      },
      "field_definitions": [
        {
          "key": "step_number",
          "name": "Step number",
          "type": "single_line_text_field",
          "description": "Display label e.g. 01, 02. Leave blank to auto-number."
        },
        {
          "key": "title",
          "name": "Title",
          "type": "single_line_text_field",
          "required": true
        },
        {
          "key": "body",
          "name": "Description",
          "type": "multi_line_text_field",
          "required": true
        },
        {
          "key": "image",
          "name": "Image",
          "type": "file_reference",
          "required": true,
          "validations": [{ "name": "file_type_options", "value": "[\"Image\"]" }]
        },
        {
          "key": "read_more_label",
          "name": "Read more label",
          "type": "single_line_text_field",
          "description": "Mobile link label. Defaults to Lire plus."
        },
        {
          "key": "read_more_url",
          "name": "Read more URL",
          "type": "url",
          "description": "Optional link shown on mobile only."
        }
      ]
    },
    {
      "name": "Before and after",
      "type": "knr_before_after",
      "access": {
        "storefront": "PUBLIC_READ"
      },
      "field_definitions": [
        {
          "key": "before_image",
          "name": "Before image",
          "type": "file_reference",
          "required": true,
          "validations": [{ "name": "file_type_options", "value": "[\"Image\"]" }]
        },
        {
          "key": "after_image",
          "name": "After image",
          "type": "file_reference",
          "required": true,
          "validations": [{ "name": "file_type_options", "value": "[\"Image\"]" }]
        },
        {
          "key": "before_label",
          "name": "Before label",
          "type": "single_line_text_field",
          "description": "Defaults to BEFORE."
        },
        {
          "key": "after_label",
          "name": "After label",
          "type": "single_line_text_field",
          "description": "Defaults to AFTER."
        }
      ]
    },
    {
      "name": "Testimonial",
      "type": "knr_testimonial",
      "access": {
        "storefront": "PUBLIC_READ"
      },
      "field_definitions": [
        {
          "key": "rating",
          "name": "Rating",
          "type": "number_decimal",
          "description": "Star rating e.g. 5 for five stars.",
          "required": true
        },
        {
          "key": "author_name",
          "name": "Author name",
          "type": "single_line_text_field",
          "required": true
        },
        {
          "key": "quote",
          "name": "Quote",
          "type": "multi_line_text_field",
          "required": true
        }
      ]
    }
  ]
}
