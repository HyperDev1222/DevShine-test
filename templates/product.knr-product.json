{
  "sections": {
    "knr-header": {
      "type": "knr-header",
      "settings": {
        "menu": "main-menu",
        "mobile_menu_label": "Open menu"
      }
    },
    "knr-breadcrumb": {
      "type": "knr-breadcrumb",
      "settings": {
        "aria_label": "Breadcrumb",
        "home_label": "Home",
        "separator": "/"
      }
    },
    "knr-product-main": {
      "type": "knr-product-main",
      "settings": {
        "show_vendor": false,
        "add_to_cart_label": "Add to cart",
        "sold_out_label": "Sold out",
        "thumbnail_label": "View image"
      }
    },
    "knr-reassurance": {
      "type": "knr-reassurance",
      "blocks": {
        "reassurance-1": {
          "type": "reassurance_item",
          "settings": {
            "title": "Free shipping",
            "text": "On orders over $50"
          }
        },
        "reassurance-2": {
          "type": "reassurance_item",
          "settings": {
            "title": "Secure payment",
            "text": "100% protected checkout"
          }
        },
        "reassurance-3": {
          "type": "reassurance_item",
          "settings": {
            "title": "Easy returns",
            "text": "30-day return policy"
          }
        }
      },
      "block_order": ["reassurance-1", "reassurance-2", "reassurance-3"],
      "settings": {
        "heading": "Why choose us"
      }
    },
    "knr-before-after": {
      "type": "knr-before-after",
      "blocks": {
        "comparison-1": {
          "type": "comparison_pair",
          "settings": {
            "before_label": "Before",
            "after_label": "After",
            "caption": "Results may vary"
          }
        }
      },
      "block_order": ["comparison-1"],
      "settings": {
        "heading": "Before & After",
        "subheading": "See the difference for yourself"
      }
    },
    "knr-how-to-use": {
      "type": "knr-how-to-use",
      "blocks": {
        "step-1": {
          "type": "step",
          "settings": {
            "title": "Cleanse",
            "body": "<p>Start with a clean, dry surface.</p>"
          }
        },
        "step-2": {
          "type": "step",
          "settings": {
            "title": "Apply",
            "body": "<p>Apply a small amount to the desired area.</p>"
          }
        },
        "step-3": {
          "type": "step",
          "settings": {
            "title": "Repeat",
            "body": "<p>Use daily for best results.</p>"
          }
        }
      },
      "block_order": ["step-1", "step-2", "step-3"],
      "settings": {
        "heading": "How to use",
        "subheading": "Follow these simple steps"
      }
    },
    "knr-faq": {
      "type": "knr-faq",
      "blocks": {
        "faq-1": {
          "type": "faq_item",
          "settings": {
            "question": "How do I use this product?",
            "answer": "<p>Apply as directed on the packaging.</p>"
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "What are the ingredients?",
            "answer": "<p>See the product description for full ingredient list.</p>"
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer 30-day returns on unopened products.</p>"
          }
        }
      },
      "block_order": ["faq-1", "faq-2", "faq-3"],
      "settings": {
        "heading": "Frequently asked questions",
        "open_first": true
      }
    },
    "knr-latest-news": {
      "type": "knr-latest-news",
      "settings": {
        "heading": "Latest news",
        "post_limit": 3,
        "show_image": true,
        "show_date": true,
        "show_excerpt": true,
        "show_view_all": true,
        "view_all_label": "View all"
      }
    },
    "knr-footer": {
      "type": "knr-footer",
      "settings": {
        "menu": "footer",
        "copyright_text": "© [shop_name]. All rights reserved.",
        "show_payment_icons": true
      }
    }
  },
  "order": [
    "knr-header",
    "knr-breadcrumb",
    "knr-product-main",
    "knr-reassurance",
    "knr-before-after",
    "knr-how-to-use",
    "knr-faq",
    "knr-latest-news",
    "knr-footer"
  ]
}
